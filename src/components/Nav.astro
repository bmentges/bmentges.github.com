---
const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};
---

<header class="site-nav">
  <div class="container-marketing nav-inner">
    <a href="/" class="brand" aria-label="Bruno Mentges — home">
      <span class="brand-mark" aria-hidden="true">B</span>
      <span class="brand-name">Bruno Mentges</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-links">
        <li><a href="/" class:list={["nav-link", isActive('/') && 'active']}>Writing</a></li>
        <li><a href="/about" class:list={["nav-link", isActive('/about') && 'active']}>About</a></li>
        <li><a href="/cv" class:list={["nav-link", isActive('/cv') && 'active']}>CV</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--border-light);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--text);
    font-weight: 600;
    font-size: 1rem;
  }
  .brand:hover { color: var(--text); }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: var(--text);
    color: var(--accent);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .brand-name {
    letter-spacing: -0.01em;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    padding: 0.5rem 0.9rem;
    color: var(--text-muted);
    font-size: 0.975rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all var(--duration) var(--ease-out);
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--bg-alt);
  }
  .nav-link.active {
    color: var(--text);
    background: var(--accent-soft);
  }
  @media (max-width: 540px) {
    .brand-name { display: none; }
    .nav-link { padding: 0.5rem 0.7rem; font-size: 0.9rem; }
  }
</style>
