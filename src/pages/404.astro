---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found — Bruno Mentges" noIndex>
  <section class="not-found">
    <div class="container-prose">
      <span class="section-label">404</span>
      <h1>Page not found.</h1>
      <p class="lede">
        The page you're looking for doesn't exist — or it moved during the redesign.
        Try the writing index, or head back home.
      </p>
      <div class="actions">
        <a href="/" class="btn btn-primary">Back to writing</a>
        <a href="/about" class="btn btn-secondary">About</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    padding: 6rem 0 4rem;
  }
  .not-found h1 {
    margin-top: 1rem;
    font-size: clamp(2.25rem, 4vw, 3rem);
    letter-spacing: -0.03em;
  }
  .not-found .lede {
    margin-top: 1.25rem;
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 55ch;
  }
  .actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
