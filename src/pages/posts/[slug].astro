---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} | Bruno Mentges`}>
  <main class="max-w-4xl mx-auto px-4 py-24">
    <a href="/" class="text-sm font-medium text-purple-400 hover:text-purple-300 transition-colors mb-12 inline-block">
      ← Back to Nexus
    </a>
    
    <article class="prose prose-invert prose-purple max-w-none">
      <header class="mb-12">
        <div class="flex items-center gap-x-3 mb-6">
          <span class="px-3 py-1 text-xs font-medium text-purple-400 bg-purple-400/10 rounded-full border border-purple-400/20 uppercase tracking-wider">
            {post.data.category}
          </span>
          <span class="text-sm text-neutral-500">
            {post.data.date?.toLocaleDateString()}
          </span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          {post.data.title}
        </h1>
        {post.data.description && (
          <p class="text-xl text-neutral-400 leading-relaxed italic">
            {post.data.description}
          </p>
        )}
      </header>
      
      <div class="bg-neutral-900/50 border border-neutral-800 rounded-3xl p-8 md:p-12">
        <Content />
      </div>

      <footer class="mt-16 pt-8 border-t border-neutral-800">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map(tag => (
            <span class="text-xs font-medium text-neutral-500 bg-neutral-800 px-3 py-1 rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      </footer>
    </article>
  </main>
</Layout>

<style is:global>
  /* Custom prose overrides for the high-end tech look */
  .prose h1, .prose h2, .prose h3 {
    @apply text-white font-bold tracking-tight;
  }
  .prose p {
    @apply text-neutral-300 leading-relaxed;
  }
  .prose code {
    @apply text-purple-300 bg-purple-500/10 px-1.5 py-0.5 rounded border border-purple-500/20 font-mono text-sm;
  }
  .prose code::before, .prose code::after {
    content: "" !important;
  }
  .prose pre {
    @apply bg-neutral-950! border border-neutral-800 rounded-2xl p-6 my-8;
  }
  .prose img {
    @apply rounded-2xl border border-neutral-800;
  }
  .prose a {
    @apply text-purple-400 no-underline hover:text-purple-300 transition-colors border-b border-purple-400/30 hover:border-purple-300;
  }
</style>
