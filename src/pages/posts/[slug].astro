---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const words = post.body.trim().split(/\s+/).length;
const rt = Math.max(1, Math.round(words / 220));

const dateLong = post.data.date?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ogImage = `/og-default.png`;
---

<Layout
  title={`${post.data.title} — Bruno Mentges`}
  description={post.data.description}
  ogImage={ogImage}
>
  <article class="post">
    <div class="container-prose">
      <a href="/" class="back-link">← Back to writing</a>

      <header class="post-header">
        {post.data.tags?.length > 0 && (
          <div class="post-tags">
            {post.data.tags.slice(0, 4).map(t => <span class="tag">{t}</span>)}
          </div>
        )}

        <h1>{post.data.title}</h1>

        {post.data.description && (
          <p class="post-lede">{post.data.description}</p>
        )}

        <div class="post-meta">
          {dateLong && <time datetime={post.data.date?.toISOString()}>{dateLong}</time>}
          <span class="dot" aria-hidden="true">·</span>
          <span>{rt} min read</span>
          {post.data.category && (
            <>
              <span class="dot" aria-hidden="true">·</span>
              <span>{post.data.category}</span>
            </>
          )}
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>

      <footer class="post-footer">
        <hr />
        <p class="cross-post">
          A version of this post may also appear on{' '}
          <a href="https://mentgesinformatica.com.br" target="_blank" rel="noopener noreferrer">
            mentgesinformatica.com.br
          </a>
          — the consultancy site.
        </p>
        <a href="/" class="back-link bottom">← Back to all writing</a>
      </footer>
    </div>
  </article>
</Layout>

<style>
  .post {
    padding: 2.5rem 0 5rem;
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .back-link:hover { color: var(--accent); }
  .back-link.bottom { margin-top: 2rem; }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-light);
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .post-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .post-lede {
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin-top: 1.25rem;
    max-width: 60ch;
  }
  .post-meta {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .post-meta .dot { color: var(--text-faint); }

  .post-footer {
    margin-top: 3.5rem;
  }
  .post-footer hr {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: 0 0 2rem;
  }
  .cross-post {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0;
  }
</style>
