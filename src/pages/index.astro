---
import Layout from '../layouts/Layout.astro';
import { NeuralBackground } from '../components/NeuralBackground';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => {
	const dateA = a.data.date || new Date(0);
	const dateB = b.data.date || new Date(0);
	return dateB.getTime() - dateA.getTime();
});
---

<Layout title="Bruno Mentges | AI Engineering">
	<NeuralBackground client:load />
	
	<main class="flex flex-col items-center">
		<!-- Hero Section -->
		<section class="flex flex-col items-center justify-center min-h-screen px-4 text-center">
			<div class="relative max-w-4xl">
				<div class="inline-flex items-center gap-x-2 px-3 py-1 text-sm font-medium text-purple-400 bg-purple-400/10 border border-purple-400/20 rounded-full mb-8">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-purple-500"></span>
					</span>
					2026 AI Roadmap Active
				</div>
				<h1 class="text-6xl font-bold tracking-tight text-white sm:text-8xl">
					The Neural <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400">Nexus</span>
				</h1>
				<p class="mt-8 text-xl leading-8 text-neutral-400 max-w-2xl mx-auto">
					Senior Data Engineer bridging the gap to AI Engineering. 
					Sharing high-impact articles and experimental intelligence projects.
				</p>
				<div class="flex items-center justify-center gap-x-6 mt-12">
					<a href="#posts" class="px-8 py-4 text-sm font-semibold text-white transition-all rounded-full bg-purple-600 border border-purple-500 hover:bg-purple-500 shadow-[0_0_20px_rgba(168,85,247,0.4)]">
						Explore Knowledge
					</a>
					<a href="http://mentgesinformatica.com.br" target="_blank" class="text-sm font-semibold leading-6 text-neutral-300 hover:text-white transition-colors">
						Mentges Informática <span aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</section>

		<!-- Bento Grid Section -->
		<section id="posts" class="w-full max-w-7xl px-4 py-24">
			<div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
				<div>
					<h2 class="text-3xl font-bold text-white mb-2">Technical Insights</h2>
					<p class="text-neutral-400">Deep dives into data systems, Python, and AI.</p>
				</div>
				<div class="h-px flex-grow bg-gradient-to-r from-neutral-800 to-transparent mx-8 hidden md:block"></div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-6 gap-6">
				{sortedPosts.map((post, index) => (
					<a 
						href={`/posts/${post.slug}`}
						class={`group relative overflow-hidden rounded-3xl border border-neutral-800 bg-neutral-900/50 p-8 transition-all hover:border-purple-500/50 hover:bg-neutral-800/50 ${
							index === 0 ? 'md:col-span-4 md:row-span-2' : 'md:col-span-2'
						}`}
					>
						<div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-cyan-500/5 opacity-0 transition-opacity group-hover:opacity-100"></div>
						<div class="relative flex flex-col h-full">
							<div class="flex items-center gap-x-3 mb-4">
								<span class="px-3 py-1 text-xs font-medium text-purple-400 bg-purple-400/10 rounded-full border border-purple-400/20 uppercase tracking-wider">
									{post.data.category || 'Engineering'}
								</span>
								<span class="text-xs text-neutral-500">
									{post.data.date ? post.data.date.toLocaleDateString() : 'Recent'}
								</span>
							</div>
							<h3 class={`font-bold text-white group-hover:text-purple-300 transition-colors ${
								index === 0 ? 'text-3xl md:text-4xl' : 'text-xl'
							}`}>
								{post.data.title}
							</h3>
							<p class="mt-4 text-neutral-400 leading-relaxed line-clamp-3">
								{post.data.description || 'Dive into the technical nuances and implementation details of this project.'}
							</p>
							<div class="mt-auto pt-8 flex items-center text-sm font-medium text-purple-400 opacity-0 transition-all translate-x-[-10px] group-hover:opacity-100 group-hover:translate-x-0">
								Read More <span class="ml-2">→</span>
							</div>
						</div>
					</a>
				))}
				
				{sortedPosts.length === 0 && (
					<div class="col-span-full py-20 text-center border border-dashed border-neutral-800 rounded-3xl">
						<p class="text-neutral-500">Intelligence gathering in progress. Posts arriving soon.</p>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>
