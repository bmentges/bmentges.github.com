---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('posts', ({ data }) => data.published !== false);

const sorted = all.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

function readingTime(text: string): number {
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 220));
}

const posts = sorted.map(p => ({
  slug: p.slug,
  ...p.data,
  rt: readingTime(p.body),
}));

const featured = posts[0];
const rest = posts.slice(1);
---

<Layout title="Bruno Mentges — Field notes on data & AI">
  <section class="hero">
    <div class="container-marketing">
      <span class="section-label">Writing</span>
      <h1>Field notes on data &amp; AI — from 28 years in the trenches.</h1>
      <p class="lede">
        Production systems at petabyte scale. LLM agents in data pipelines. Platform design
        decisions that age well. Written by a senior data engineer in Rio de Janeiro for
        engineering leaders and builders 10+ years in.
      </p>
      <div class="hero-meta">
        <span>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
        {featured && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span>Last updated <time datetime={featured.date?.toISOString()}>{featured.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
          </>
        )}
        <span class="dot" aria-hidden="true">·</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </section>

  {featured && (
    <section class="featured-section">
      <div class="container-marketing">
        <div class="section-head">
          <span class="section-label">Latest</span>
        </div>
        <PostCard
          href={`/posts/${featured.slug}`}
          title={featured.title}
          description={featured.description}
          date={featured.date}
          tags={featured.tags}
          readingTime={featured.rt}
          featured
        />
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section class="list-section">
      <div class="container-marketing">
        <div class="section-head">
          <span class="section-label">More writing</span>
        </div>
        <div class="post-grid">
          {rest.map(p => (
            <PostCard
              href={`/posts/${p.slug}`}
              title={p.title}
              description={p.description}
              date={p.date}
              tags={p.tags}
              readingTime={p.rt}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {posts.length === 0 && (
    <section class="empty-section">
      <div class="container-marketing">
        <p class="empty-note">No posts yet — writing in progress.</p>
      </div>
    </section>
  )}

  <section class="about-teaser">
    <div class="container-marketing">
      <div class="about-card">
        <span class="section-label">About</span>
        <h2>Engineer first. Consultant second.</h2>
        <p>
          Senior Data &amp; AI Engineer with ~25 years shipping software and ~15 years
          specializing in data platforms — across marketing, fintech, logtech, travel, and media.
          Currently integrating LLM agents into production data engineering.
        </p>
        <div class="about-actions">
          <a href="/about" class="btn btn-primary">Read the full story →</a>
          <a href="/cv" class="btn btn-secondary">View CV</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 5rem 0 3rem;
  }
  .hero h1 {
    margin-top: 1rem;
    max-width: 22ch;
  }
  .hero .lede {
    margin-top: 1.5rem;
    max-width: 60ch;
    font-size: 1.3125rem;
    line-height: 1.55;
    color: var(--text-secondary);
  }
  .hero-meta {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .hero-meta .dot { color: var(--text-faint); }
  .hero-meta a {
    color: var(--accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .featured-section,
  .list-section,
  .empty-section {
    padding: 2.5rem 0;
  }
  .section-head {
    margin-bottom: 1.5rem;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .empty-note {
    color: var(--text-muted);
    font-style: italic;
    padding: 3rem 0;
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
  }

  .about-teaser {
    padding: 4rem 0 2rem;
  }
  .about-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    max-width: 720px;
  }
  .about-card h2 {
    margin-top: 0.75rem;
  }
  .about-card p {
    margin-top: 1rem;
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 58ch;
  }
  .about-actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .hero { padding: 3rem 0 1.5rem; }
    .hero .lede { font-size: 1.15rem; }
    .about-card { padding: 1.75rem; }
  }
</style>
